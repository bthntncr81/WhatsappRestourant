{
  "name": "manager",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/manager/src",
  "prefix": "mgr",
  "tags": ["scope:manager", "type:app"],
  "targets": {
    "build": {
      "executor": "@angular-devkit/build-angular:application",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/apps/manager",
        "index": "apps/manager/src/index.html",
        "browser": "apps/manager/src/main.ts",
        "polyfills": ["zone.js"],
        "tsConfig": "apps/manager/tsconfig.app.json",
        "inlineStyleLanguage": "scss",
        "assets": [
          {
            "glob": "**/*",
            "input": "apps/manager/public"
          }
        ],
        "styles": ["apps/manager/src/styles.scss"],
        "scripts": []
      },
      "configurations": {
        "production": {
          "budgets": [
            { "type": "initial", "maximumWarning": "600kb", "maximumError": "1.5mb" },
            { "type": "anyComponentStyle", "maximumWarning": "10kb", "maximumError": "60kb" }
          ],
          "outputHashing": "all",
          "fileReplacements": [
            {
              "replace": "apps/manager/src/environments/environment.ts",
              "with": "apps/manager/src/environments/environment.prod.ts"
            }
          ]
        },
        "development": {
          "optimization": false,
          "extractLicenses": false,
          "sourceMap": true
        }
      },
      "defaultConfiguration": "production"
    },
    "serve": {
      "executor": "@angular-devkit/build-angular:dev-server",
      "configurations": {
        "production": { "buildTarget": "manager:build:production" },
        "development": { "buildTarget": "manager:build:development" }
      },
      "defaultConfiguration": "development",
      "options": { "port": 4203 }
    }
  }
}
